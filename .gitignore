# Data (large, regenerable — never commit)
data/raw/*
data/interim/*
!data/raw/.gitkeep        # keep the empty folder tracked in git
!data/interim/.gitkeep

# MySQL credentials (sensitive)
config/secrets.yaml

# Python environment & caches
.venv/
__pycache__/
*.pyc
.ruff_cache/

# OS noise
.DS_Store
Thumbs.db
