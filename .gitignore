# We add ignore rules as we add the things they protect (kept lean on purpose).

# Data (large, regenerable — never commit)
data/raw/*
data/interim/*
!data/raw/.gitkeep        # keep the empty folder tracked in git
!data/interim/.gitkeep

# Python environment & caches
.venv/
__pycache__/
*.pyc
.ruff_cache/

# OS noise
.DS_Store
Thumbs.db
